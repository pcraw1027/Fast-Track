<%= form_with(model: product) do |form| %>
  <% if product.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(product.errors.count, "error") %> prohibited this product from being saved:</h2>

      <ul>
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :company_id %>
    <%= form.collection_select :company_id, @companies, :id, :name, class: "form-control"  %>
  </div>

  <div class="field">
    <%= form.label :name %>
    <%= form.text_field :name %>
  </div>

  <div class="field">
    <%= form.label :image %>
    <%= form.text_field :image %>
  </div>

  <div class="field">
    <%= form.label :description %>
    <%= form.text_field :description %>
  </div>

  <div class="field">
    <%= form.label :barcode %>
    <%= form.text_field :barcode %>
  </div>

  <div class="field">
    <%= form.label :qrcode %>
    <%= form.text_field :qrcode %>
  </div>

  <div class="field">
    <%= form.label :size %>
    <%= form.text_field :size %>
  </div>

  <div class="field">
    <%= form.label :segment_id %>
     <%= form.collection_select :segment_id, @segments, :id, :code, class: "form-control"  %>
  </div>

  <div class="field">
    <%= form.label :family_id %>
     <%= form.collection_select :family_id, @families, :id, :code, class: "form-control"  %>
  </div>

  <div class="field">
    <%= form.label :klass_id %>
     <%= form.collection_select :klass_id, @klasses, :id, :code, class: "form-control"  %>
  </div>

  <div class="field">
    <%= form.label :brick_id %>
     <%= form.collection_select :brick_id, @bricks, :id, :code, class: "form-control"  %>
  </div>

  <div class="actions">
    <%= form.submit "Submit", class: 'btn btn-secondary' %>
  </div>
<% end %>
