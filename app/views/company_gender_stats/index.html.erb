<p id="notice"><%= notice %></p>

<h1>Company Gender Stats</h1>

<table>
  <thead>
    <tr>
      <th>Company</th>
      <th>Gender type</th>
      <th>Employee type</th>
      <th>Count</th>
      <th>Percentage</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @company_gender_stats.each do |company_gender_stat| %>
      <tr>
        <td><%= company_gender_stat.company_id %></td>
        <td><%= company_gender_stat.gender_type_id %></td>
        <td><%= company_gender_stat.employee_type_id %></td>
        <td><%= company_gender_stat.count %></td>
        <td><%= company_gender_stat.percentage %></td>
        <td><%= link_to 'Show', company_gender_stat %></td>
        <td><%= link_to 'Edit', edit_company_gender_stat_path(company_gender_stat) %></td>
        <td><%= link_to 'Destroy', company_gender_stat, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Company Gender Stat', new_company_gender_stat_path %>
